{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      default_openai_model: { type: "string", default: "gpt-5-mini" },
      openai_api_key: { type: "string", secret: true },
      openai_api_url: { type: "string", default: "https://openrouter.ai/api/v1" }
    },
    required: [],
    additionalProperties: false,
  },

  // Runtime configuration
  program: {
    image: "ghcr.io/danessely/meta-game-negotiatior:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9010",

    env: {
      DEFAULT_OPENAI_MODEL: "${config.default_openai_model}",
      OPENAI_API_KEY: "${config.openai_api_key}",
      OPENAI_API_URL: "${config.openai_api_url}",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9010 }, // ensure port matches your entrypoint
      ],
    },
  },

  // Capabilities provided by this agent
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  // Capabilities exposed to the scenario
  exports: { a2a: "a2a" },
}
